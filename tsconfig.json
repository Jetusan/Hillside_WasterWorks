{
"compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
},
"references": [
    { "path": "./tsconfig.main.json" },
    { "path": "./tsconfig.renderer.json" }
],
"exclude": ["node_modules", "build", "dist"]
}