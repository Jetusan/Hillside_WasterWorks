{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./build/main",
    "rootDir": "./src",
    "noEmit": false,
    "composite": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0" 
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "src/renderer"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}